{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node"]
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/ipc/bootstrap.ts",
    "src/utils/**/*.ts",
    "src/vite-env.d.ts",
    "src/types.d.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "src/runtime/**/*"
  ]
}
