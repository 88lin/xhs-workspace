{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XHS Atelier",
  "version": "0.1.0",
  "identifier": "com.xhsatelier.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "XHS Atelier",
        "label": "main",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "publisher": "茉灵智库",
    "homepage": "https://github.com/88lin/xhs-workspace",
    "shortDescription": "A desktop studio for Xiaohongshu capture, library management, and RedClaw drafting.",
    "longDescription": "XHS Atelier combines capture intake, subject organization, creation briefs, manuscripts, and RedClaw generation into one open-source Tauri desktop workspace.",
    "license": "MIT",
    "licenseFile": "../../../LICENSE",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
